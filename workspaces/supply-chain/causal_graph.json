  "scenarios": {
    "外调品分析": {
      "description": "分析从外部工厂调入产品的情况、成本及优化建议",
      "start_node": "外调品增加",
      "keywords": [
        "外调",
        "调货",
        "外地",
        "运费",
        "物流成本",
        "本地生产",
        "供货工厂"
      ],
      "sub_questions": {
        "外调品总量与占比": {
          "tables": [
            "sales_delivery"
          ],
          "filter": "is_external_transfer = 1",
          "measures": [
            "SUM(deliv_qty_mt)",
            "COUNT(DISTINCT delivnum)"
          ],
          "dimensions": [
            "月份",
            "分公司",
            "产线"
          ],
          "description": "统计外调品的提货量、提单数及占总量比例"
        },
        "外调品产品结构": {
          "tables": [
            "sales_delivery"
          ],
          "filter": "is_external_transfer = 1",
          "measures": [
            "SUM(deliv_qty_mt)"
          ],
          "dimensions": [
            "deliv_mat_name",
            "deliv_prodctnline_descrptn"
          ],
          "description": "哪些产品/产线的外调量最大"
        },
        "外调品来源工厂": {
          "tables": [
            "sales_delivery"
          ],
          "filter": "is_external_transfer = 1",
          "measures": [
            "SUM(deliv_qty_mt)"
          ],
          "dimensions": [
            "deliv_sply_plant_descrptn"
          ],
          "description": "外调品来自哪些工厂"
        },
        "外调品物流成本对比": {
          "tables": [
            "sales_delivery"
          ],
          "measures": [
            "AVG(logistics_cost_per_mt)"
          ],
          "dimensions": [
            "is_external_transfer"
          ],
          "description": "外调品vs本地供货的平均物流成本差异"
        },
        "外调品月度趋势": {
          "tables": [
            "sales_delivery"
          ],
          "filter": "is_external_transfer = 1",
          "measures": [
            "SUM(deliv_qty_mt)"
          ],
          "dimensions": [
            "strftime('%Y-%m', deliv_crt_time)"
          ],
          "description": "外调品数量的月度变化趋势",
          "chart_type": "line"
        },
        "本地可生产但仍外调": {
          "tables": [
            "sales_delivery"
          ],
          "description": "识别本地可以生产但仍从外地调入的产品（优化重点）",
          "note": "需结合物料的local_producible属性——当前仿真数据中通过is_external_transfer和产品名推断"
        }
      }
    },
    "销量达成分析": {
      "description": "分析销量目标完成情况及未达成的原因",
      "start_node": "销量达成不足",
      "keywords": [
        "达成",
        "完成率",
        "进度",
        "计划",
        "滚动",
        "缺口",
        "差多少",
        "目标"
      ],
      "sub_questions": {
        "整体达成率": {
          "tables": [
            "sales_delivery",
            "rolling_plan"
          ],
          "join": "按busline_code+brnch_code+stats_yearmth关联",
          "measures": [
            "SUM(deliv_qty_mt) / SUM(rllng_planqty_mt)"
          ],
          "description": "当月累计提货量vs滚动计划量"
        },
        "分公司达成率": {
          "tables": [
            "sales_delivery",
            "rolling_plan"
          ],
          "dimensions": [
            "brnch_descrptn"
          ],
          "description": "按分公司拆解达成情况"
        },
        "产线达成率": {
          "tables": [
            "sales_delivery",
            "rolling_plan"
          ],
          "dimensions": [
            "deliv_prodctnline_descrptn"
          ],
          "description": "按产线拆解达成缺口"
        },
        "客户维度缺口": {
          "tables": [
            "sales_delivery",
            "rolling_plan"
          ],
          "dimensions": [
            "deliv_soldto_name"
          ],
          "description": "计划有量但实际挂零的客户"
