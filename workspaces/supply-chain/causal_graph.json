  "analysis_patterns": [
    {
      "name": "upstream_dependency_backtracking",
      "trigger": "外调品 外调 采购 库存 告急 缺货 shortage procurement",
      "domain": "supply_chain_attribution",
      "steps": [
        {
          "step_type": "MetricCheck",
          "description": "检查入口指标当前值与阈值"
        },
        {
          "step_type": "CypherQuery",
          "description": "查询上游因果节点"
        },
        {
          "step_type": "MetricCheck",
          "description": "逐层验证上游节点异常状态"
        },
        {
          "step_type": "CypherQuery",
          "description": "关联变更记录与时间窗口"
        },
        {
          "step_type": "Aggregate",
          "description": "综合多路径证据生成归因报告"
        }
      ],
      "parameters": [
        "entry_metric",
        "time_period",
        "anomaly_threshold"
      ]
    },
    {
      "name": "sales_achievement_attribution",
      "trigger": "销量 达成 完成率 目标 销售 achievement sales",
