      ]
    },
    {
      "id": "full_demand_surge",
      "name": "促销全链路客户影响链",
      "path": [
        "促销拉动",
        "订单倒挂",
        "加班工时异常",
        "良品率下降",
        "客户投诉增加"
      ],
      "trigger_keywords": [
        "促销导致投诉",
