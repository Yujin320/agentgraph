{
  "version": "2.0",
  "description": "供应链归因图谱 v2.0 — 6层因果网络，覆盖供应→生产→库存→销售→客户→成本全链路",
  "layers": {
    "供应层": {
      "color": "#8B5CF6",
      "nodes": {
        "原材料到货延迟": {
          "tables": [
            "procurement"
          ],
          "metric_sql": "SELECT ROUND(AVG(delay_days),1) as v FROM procurement WHERE status='延迟' AND po_yearmth='{ym}'",
          "threshold": {
            "warn": 3,
            "alert": 7
          },
          "description": "采购订单平均延迟天数",
          "drill_down": {
            "by_supplier": "SELECT supplier_code, supplier_name, ROUND(AVG(delay_days),1) as avg_delay_days, COUNT(*) as delayed_orders FROM procurement WHERE status='延迟' AND po_yearmth='{ym}' GROUP BY supplier_code, supplier_name ORDER BY avg_delay_days DESC",
            "by_material": "SELECT raw_material_name, ROUND(AVG(delay_days),1) as avg_delay_days, COUNT(*) as delayed_orders, target_plant_descrptn FROM procurement WHERE status='延迟' AND po_yearmth='{ym}' GROUP BY raw_material_name, target_plant_descrptn ORDER BY avg_delay_days DESC"
          }
        },
        "供应商交期不稳定": {
          "tables": [
            "procurement"
          ],
          "metric_sql": "SELECT COUNT(DISTINCT supplier_code) as v FROM procurement WHERE delay_days > 5 AND po_yearmth='{ym}'",
          "threshold": {
            "warn": 2,
            "alert": 4
          },
          "description": "延迟超5天的供应商数量"
        }
      }
    },
    "生产层": {
      "color": "#F59E0B",
      "nodes": {
        "产量不足": {
          "tables": [
            "production_output"
          ],
          "metric_sql": "SELECT ROUND(100.0*SUM(actual_qty_mt)/NULLIF(SUM(planned_qty_mt),0),1) as v FROM production_output WHERE record_yearmth='{ym}'",
          "threshold": {
            "warn": 85,
            "alert": 70
          },
          "threshold_direction": "below",
          "description": "实际产量/计划产量 完成率",
          "drill_down": {
            "by_factory": "SELECT plant_code, plant_descrptn, ROUND(100.0*SUM(actual_qty_mt)/NULLIF(SUM(planned_qty_mt),0),1) as completion_rate FROM production_output WHERE record_yearmth='{ym}' GROUP BY plant_code, plant_descrptn ORDER BY completion_rate",
            "by_line": "SELECT production_line, ROUND(100.0*SUM(actual_qty_mt)/NULLIF(SUM(planned_qty_mt),0),1) as completion_rate FROM production_output WHERE record_yearmth='{ym}' AND plant_code='{plant}' GROUP BY production_line ORDER BY completion_rate"
          }
        },
        "良品率下降": {
          "tables": [
            "quality_inspection"
          ],
          "metric_sql": "SELECT ROUND(AVG(defect_rate)*100,2) as v FROM quality_inspection WHERE inspection_yearmth='{ym}'",
          "threshold": {
            "warn": 3,
            "alert": 5
          },
          "description": "平均质检不合格率(%)",
          "drill_down": {
            "by_factory": "SELECT plant_descrptn, ROUND(AVG(defect_rate)*100,2) as defect_rate_pct, COUNT(*) as batch_cnt FROM quality_inspection WHERE inspection_yearmth='{ym}' GROUP BY plant_descrptn ORDER BY defect_rate_pct DESC",
            "by_line": "SELECT production_line, ROUND(AVG(defect_rate)*100,2) as defect_rate_pct, COUNT(*) as batch_cnt FROM quality_inspection WHERE inspection_yearmth='{ym}' AND plant_code='{plant}' GROUP BY production_line ORDER BY defect_rate_pct DESC"
          }
        },
        "加班工时异常": {
          "tables": [
            "overtime_hours"
          ],
          "metric_sql": "SELECT ROUND(SUM(overtime_hours),0) as v FROM overtime_hours WHERE record_yearmth='{ym}'",
          "threshold": {
            "warn": 5000,
            "alert": 8000
          },
          "description": "月度总加班工时",
          "drill_down": {
            "by_factory": "SELECT plant_descrptn, ROUND(SUM(overtime_hours),0) as total_ot_hours, SUM(worker_count) as total_workers FROM overtime_hours WHERE record_yearmth='{ym}' GROUP BY plant_descrptn ORDER BY total_ot_hours DESC",
            "by_workshop": "SELECT workshop, ROUND(SUM(overtime_hours),0) as total_ot_hours, SUM(worker_count) as total_workers FROM overtime_hours WHERE record_yearmth='{ym}' AND plant_code='{plant}' GROUP BY workshop ORDER BY total_ot_hours DESC"
          }
        }
      }
    },
    "库存层": {
      "color": "#10B981",
      "nodes": {
        "库存告急": {
          "tables": [
            "inventory"
          ],
          "metric_sql": "SELECT COUNT(*) as v FROM inventory WHERE stock_status IN ('缺货','低于安全库存') AND snapshot_yearmth='{ym}'",
          "threshold": {
            "warn": 10,
            "alert": 30
          },
          "description": "库存告急的物料-工厂记录数",
          "drill_down": {
            "by_factory": "SELECT plant_descrptn, COUNT(*) as shortage_items, SUM(CASE WHEN stock_status='缺货' THEN 1 ELSE 0 END) as stockout_items FROM inventory WHERE stock_status IN ('缺货','低于安全库存') AND snapshot_yearmth='{ym}' GROUP BY plant_descrptn ORDER BY shortage_items DESC",
            "by_material": "SELECT mat_name, plant_descrptn, stock_status, ROUND(days_of_supply,1) as days_of_supply FROM inventory WHERE stock_status IN ('缺货','低于安全库存') AND snapshot_yearmth='{ym}' ORDER BY days_of_supply ASC"
          }
        }
      }
    },
    "销售层": {
      "color": "#3B82F6",
      "nodes": {
        "销量达成不足": {
          "tables": [
            "sales_delivery",
            "rolling_plan"
          ],
          "metric_sql": "SELECT ROUND(SUM(d.deliv_qty_mt)*100.0/NULLIF(SUM(p.rllng_planqty_mt),0),1) as v FROM sales_delivery d LEFT JOIN rolling_plan p ON d.brnch_code=p.brnch_code AND d.busline_code=p.busline_code AND strftime('%Y%m',d.deliv_crt_time)=p.stats_yearmth WHERE strftime('%Y%m',d.deliv_crt_time)='{ym}' AND d.deliv_retrngds_identfctn IS NULL",
          "threshold": {
            "warn": 80,
            "alert": 60
          },
          "threshold_direction": "below",
          "description": "销量达成率(%)"
        },
        "外调品增加": {
          "tables": [
            "sales_delivery"
          ],
          "metric_sql": "SELECT ROUND(100.0*SUM(CASE WHEN is_external_transfer=1 THEN deliv_qty_mt ELSE 0 END)/NULLIF(SUM(deliv_qty_mt),0),1) as v FROM sales_delivery WHERE strftime('%Y%m',deliv_crt_time)='{ym}' AND deliv_retrngds_identfctn IS NULL",
          "threshold": {
            "warn": 25,
            "alert": 40
          },
          "description": "外调品占比(%)",
          "drill_down": {
            "by_factory": "SELECT deliv_sply_plant_descrptn, ROUND(SUM(deliv_qty_mt),1) as transfer_qty_mt, COUNT(DISTINCT delivnum) as order_cnt FROM sales_delivery WHERE is_external_transfer=1 AND strftime('%Y%m',deliv_crt_time)='{ym}' AND deliv_retrngds_identfctn IS NULL GROUP BY deliv_sply_plant_descrptn ORDER BY transfer_qty_mt DESC",
            "by_material": "SELECT deliv_mat_name, deliv_prodctnline_descrptn, ROUND(SUM(deliv_qty_mt),1) as transfer_qty_mt FROM sales_delivery WHERE is_external_transfer=1 AND strftime('%Y%m',deliv_crt_time)='{ym}' AND deliv_retrngds_identfctn IS NULL GROUP BY deliv_mat_name, deliv_prodctnline_descrptn ORDER BY transfer_qty_mt DESC"
          }
        },
        "订单倒挂": {
          "tables": [
            "sales_order"
          ],
          "metric_sql": "SELECT ROUND(100.0*SUM(CASE WHEN order_dlvry_sts_code!='C' THEN order_qty_mt ELSE 0 END)/NULLIF(SUM(order_qty_mt),0),1) as v FROM sales_order WHERE strftime('%Y%m',order_crt_date)='{ym}'",
          "threshold": {
            "warn": 15,
            "alert": 30
          },
          "description": "订单倒挂率(%)"
        },
        "促销拉动": {
          "tables": [
            "promotion"
          ],
          "metric_sql": "SELECT COUNT(*) as v FROM promotion WHERE promo_yearmth='{ym}'",
          "threshold": {
            "warn": 15,
            "alert": 25
          },
          "description": "当月促销活动数"
        }
      }
    },
    "客户层": {
      "color": "#EF4444",
      "nodes": {
        "客户投诉增加": {
          "tables": [
            "customer_complaint"
          ],
          "metric_sql": "SELECT COUNT(*) as v FROM customer_complaint WHERE complaint_yearmth='{ym}'",
          "threshold": {
            "warn": 50,
            "alert": 80
          },
          "description": "当月客户投诉数",
          "drill_down": {
            "by_region": "SELECT brnch_descrptn, COUNT(*) as complaint_cnt, ROUND(AVG(resolution_days),1) as avg_resolution_days FROM customer_complaint WHERE complaint_yearmth='{ym}' GROUP BY brnch_descrptn ORDER BY complaint_cnt DESC",
            "by_complaint_type": "SELECT complaint_type, severity, COUNT(*) as complaint_cnt, SUM(CASE WHEN is_resolved=0 THEN 1 ELSE 0 END) as unresolved_cnt FROM customer_complaint WHERE complaint_yearmth='{ym}' GROUP BY complaint_type, severity ORDER BY complaint_cnt DESC"
          }
        },
        "交期延迟投诉": {
          "tables": [
            "customer_complaint"
          ],
          "metric_sql": "SELECT COUNT(*) as v FROM customer_complaint WHERE complaint_type='交期延迟' AND complaint_yearmth='{ym}'",
          "threshold": {
            "warn": 15,
            "alert": 30
          },
          "description": "交期延迟类投诉数"
        }
      }
    },
    "成本层": {
      "color": "#6366F1",
      "nodes": {
        "物流成本上升": {
          "tables": [
            "sales_delivery"
          ],
          "metric_sql": "SELECT ROUND(AVG(logistics_cost_per_mt),1) as v FROM sales_delivery WHERE is_external_transfer=1 AND strftime('%Y%m',deliv_crt_time)='{ym}' AND deliv_retrngds_identfctn IS NULL",
          "threshold": {
            "warn": 200,
            "alert": 300
          },
          "description": "外调品平均物流成本(元/吨)"
        },
        "加班成本上升": {
          "tables": [
            "overtime_hours"
          ],
          "metric_sql": "SELECT ROUND(SUM(overtime_cost),0) as v FROM overtime_hours WHERE record_yearmth='{ym}'",
          "threshold": {
            "warn": 500000,
            "alert": 800000
          },
          "description": "月度总加班成本(元)"
        },
        "质量损失成本": {
          "tables": [
            "production_output"
          ],
          "metric_sql": "SELECT ROUND(SUM(scrap_qty_mt),1) as v FROM production_output WHERE record_yearmth='{ym}'",
          "threshold": {
            "warn": 50,
            "alert": 100
          },
          "description": "月度报废量(吨)"
        }
      }
    }
  },
  "causal_edges": [
