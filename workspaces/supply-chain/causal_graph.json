  ],
  "causal_chains": [
    {
      "id": "supply_disruption",
      "name": "供应链中断传导链",
      "path": [
        "原材料到货延迟",
        "产量不足",
        "库存告急",
        "外调品增加",
        "物流成本上升"
      ],
      "trigger_keywords": [
        "为什么外调品增加",
        "物流成本为什么高",
        "外调原因",
        "原材料延迟影响",
        "供应中断"
      ]
    },
    {
      "id": "quality_cascade",
      "name": "质量问题传导链",
      "path": [
        "加班工时异常",
        "良品率下降",
        "客户投诉增加",
