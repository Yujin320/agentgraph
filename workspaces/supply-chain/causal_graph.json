      "sub_questions": {
        "促销活动概览": {
          "tables": [
            "promotion"
          ],
          "measures": [
            "COUNT(*)",
            "SUM(budget_amount)",
            "SUM(actual_spend)"
          ],
          "dimensions": [
            "promo_yearmth",
            "channel_descrptn"
          ],
          "description": "各月各渠道促销活动数及费用执行情况"
        },
        "促销费用执行": {
          "tables": [
            "promotion"
          ],
          "measures": [
            "SUM(budget_amount)",
            "SUM(actual_spend)"
          ],
          "dimensions": [
            "brnch_descrptn",
            "promo_name"
          ],
          "description": "促销预算vs实际花费对比，识别超支情况"
        },
        "促销对销量拉动": {
          "tables": [
            "promotion",
            "sales_order"
          ],
          "join": "brnch_code + mat_code + promo_yearmth",
          "measures": [
            "SUM(order_qty_mt)",
            "expected_lift_pct"
          ],
          "dimensions": [
            "brnch_descrptn",
            "channel_descrptn"
          ],
          "description": "促销期间订单量与预期提升的对比"
        },
        "渠道促销效率": {
          "tables": [
            "promotion"
          ],
          "measures": [
            "AVG(actual_spend/budget_amount)",
            "AVG(expected_lift_pct)"
          ],
          "dimensions": [
            "channel_descrptn"
          ],
          "description": "不同渠道的促销费效比对比",
          "chart_type": "bar"
        }
      }
    }
