            "severity"
          ],
          "description": "不合格批次按缺陷类型和严重程度分布",
          "chart_type": "pie"
        }
      }
    },
    "客户投诉分析": {
      "description": "分析客户投诉数量、类型、严重程度及处理效率",
      "start_node": "客户投诉增加",
      "keywords": [
        "投诉",
        "客诉",
        "退换货",
        "客户满意度",
        "处理天数",
        "质量投诉"
