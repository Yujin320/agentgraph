          "description": "月度投诉数量及类型分布趋势",
          "chart_type": "line"
        },
        "分公司投诉对比": {
          "tables": [
            "customer_complaint"
          ],
          "measures": [
            "COUNT(*)",
            "AVG(resolution_days)"
          ],
          "dimensions": [
            "brnch_descrptn"
          ],
          "description": "各分公司投诉量及平均处理天数对比"
        },
        "严重投诉分析": {
          "tables": [
            "customer_complaint"
          ],
          "filter": "severity IN ('重要', '紧急')",
          "measures": [
            "COUNT(*)",
            "SUM(CASE WHEN is_resolved=0 THEN 1 ELSE 0 END)"
          ],
          "dimensions": [
            "brnch_descrptn",
            "complaint_type"
          ],
          "description": "重要和紧急投诉的分布及未解决情况"
        },
        "质量投诉与批次关联": {
          "tables": [
            "customer_complaint",
            "quality_inspection"
          ],
          "join": "related_batch_id = batch_id",
          "measures": [
            "COUNT(*)"
          ],
          "dimensions": [
            "defect_type"
          ],
          "description": "可追溯到质检批次的投诉，分析缺陷类型与投诉的关联"
        }
      }
    },
    "促销效果分析": {
      "description": "分析促销活动的覆盖范围、费用执行及对销量的拉动效果",
      "start_node": "促销拉动",
      "keywords": [
