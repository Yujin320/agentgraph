    "生产质量分析": {
      "description": "分析工厂生产产量达成、良品率及质检异常情况",
      "start_node": "良品率下降",
      "keywords": [
        "生产",
        "产量",
        "良品率",
        "质检",
        "不合格",
        "报废",
        "质量",
