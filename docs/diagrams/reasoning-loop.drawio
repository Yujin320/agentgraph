<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Title -->
    <mxCell id="title" value="DataAgent v2 - Agentic 推理循环 (LangGraph)" style="text;fontSize=18;fontStyle=1;fontColor=#1a1a2e;align=center;" vertex="1" parent="1">
      <mxGeometry x="150" y="10" width="600" height="30" as="geometry"/>
    </mxCell>

    <!-- User Input -->
    <mxCell id="user" value="用户提问" style="shape=mxgraph.flowchart.terminator;whiteSpace=wrap;fillColor=#4f46e5;fontColor=#fff;strokeColor=#3730a3;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="370" y="55" width="140" height="40" as="geometry"/>
    </mxCell>

    <!-- Intent Node -->
    <mxCell id="intent" value="1. 意图识别 (Intent)&#xa;LLM 分类: 查询/归因/对比/趋势&#xa;关键词匹配 + 语义理解" style="rounded=1;whiteSpace=wrap;fillColor=#E8EAF6;strokeColor=#283593;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="330" y="120" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- Strategy Router -->
    <mxCell id="router" value="策略路由" style="rhombus;whiteSpace=wrap;fillColor=#F3E5F5;strokeColor=#6A1B9A;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="385" y="210" width="110" height="70" as="geometry"/>
    </mxCell>

    <!-- Strategy branches (left) -->
    <mxCell id="strat_causal" value="因果归因&#xa;KG 遍历" style="rounded=1;whiteSpace=wrap;fillColor=#CE93D8;strokeColor=#6A1B9A;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="60" y="220" width="90" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="strat_stat" value="统计分析&#xa;相关系数" style="rounded=1;whiteSpace=wrap;fillColor=#CE93D8;strokeColor=#6A1B9A;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="170" y="220" width="90" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="strat_comp" value="对比分析&#xa;环比/切片" style="rounded=1;whiteSpace=wrap;fillColor=#CE93D8;strokeColor=#6A1B9A;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="610" y="220" width="90" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="strat_trend" value="趋势追踪&#xa;时序分解" style="rounded=1;whiteSpace=wrap;fillColor=#CE93D8;strokeColor=#6A1B9A;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="720" y="220" width="90" height="45" as="geometry"/>
    </mxCell>

    <!-- Strategy edges -->
    <mxCell id="er1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6A1B9A;fontSize=9;" edge="1" parent="1" source="router" target="strat_causal">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="er2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6A1B9A;fontSize=9;" edge="1" parent="1" source="router" target="strat_stat">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="er3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6A1B9A;fontSize=9;" edge="1" parent="1" source="router" target="strat_comp">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="er4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6A1B9A;fontSize=9;" edge="1" parent="1" source="router" target="strat_trend">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Plan Node -->
    <mxCell id="plan" value="2. 任务规划 (Plan)&#xa;LLM 将问题分解为&#xa;可执行子任务列表" style="rounded=1;whiteSpace=wrap;fillColor=#E8EAF6;strokeColor=#283593;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="330" y="310" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- SQL Gen Node with interrupt -->
    <mxCell id="sqlgen_box" value="" style="rounded=1;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=2;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="305" y="395" width="270" height="85" as="geometry"/>
    </mxCell>
    <mxCell id="sqlgen" value="3. SQL 生成 (sql_gen)&#xa;KG Schema 聚焦 + ChromaDB RAG&#xa;+ 错误修正 Prompt (重试时)" style="rounded=1;whiteSpace=wrap;fillColor=#E8EAF6;strokeColor=#283593;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="315" y="400" width="250" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="interrupt_label" value="interrupt() - 用户可审批/编辑 SQL" style="text;fontSize=10;fontStyle=2;fontColor=#F57F17;" vertex="1" parent="1">
      <mxGeometry x="315" y="458" width="250" height="18" as="geometry"/>
    </mxCell>

    <!-- Execute Node -->
    <mxCell id="execute" value="4. 执行 (Execute)&#xa;SQLAlchemy 执行&#xa;捕获错误 + 结果" style="rounded=1;whiteSpace=wrap;fillColor=#E8EAF6;strokeColor=#283593;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="330" y="510" width="220" height="55" as="geometry"/>
    </mxCell>

    <!-- Reflect Decision -->
    <mxCell id="reflect" value="5. 反思 (Reflect)" style="rhombus;whiteSpace=wrap;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="370" y="595" width="140" height="80" as="geometry"/>
    </mxCell>

    <!-- Reflect conditions -->
    <mxCell id="cond_retry" value="SQL 错误&#xa;retry &lt; 3" style="text;fontSize=10;fontColor=#C62828;fontStyle=2;align=center;" vertex="1" parent="1">
      <mxGeometry x="155" y="605" width="80" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="cond_drill" value="结果异常&#xa;需要下钻" style="text;fontSize=10;fontColor=#E65100;fontStyle=2;align=center;" vertex="1" parent="1">
      <mxGeometry x="640" y="605" width="80" height="30" as="geometry"/>
    </mxCell>

    <!-- Conclude Node -->
    <mxCell id="conclude" value="6. 结论生成 (Conclude)&#xa;LLM 综合所有步骤结果&#xa;生成解读 + 图表 + 建议" style="rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;fontStyle=1;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="330" y="720" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- Output -->
    <mxCell id="output" value="SSE 实时推送至前端" style="shape=mxgraph.flowchart.terminator;whiteSpace=wrap;fillColor=#4f46e5;fontColor=#fff;strokeColor=#3730a3;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="350" y="815" width="180" height="35" as="geometry"/>
    </mxCell>

    <!-- Main flow edges -->
    <mxCell id="f1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#283593;" edge="1" parent="1" source="user" target="intent">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#283593;" edge="1" parent="1" source="intent" target="router">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#283593;" edge="1" parent="1" source="router" target="plan">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#283593;" edge="1" parent="1" source="plan" target="sqlgen">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#283593;" edge="1" parent="1" source="sqlgen" target="execute">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#283593;" edge="1" parent="1" source="execute" target="reflect">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f7" value="正常" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2E7D32;fontColor=#2E7D32;fontSize=10;" edge="1" parent="1" source="reflect" target="conclude">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f8" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#283593;" edge="1" parent="1" source="conclude" target="output">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Retry loop (left arc) -->
    <mxCell id="retry_edge" value="重试" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C62828;fontColor=#C62828;fontSize=10;dashed=1;" edge="1" parent="1" source="reflect" target="sqlgen">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="240" y="635"/>
          <mxPoint x="240" y="430"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Drill loop (right arc) -->
    <mxCell id="drill_edge" value="下钻" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E65100;fontColor=#E65100;fontSize=10;dashed=1;" edge="1" parent="1" source="reflect" target="plan">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="640" y="635"/>
          <mxPoint x="640" y="340"/>
          <mxPoint x="550" y="340"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- SSE events sidebar -->
    <mxCell id="sse_box" value="SSE Events (实时推送)&#xa;&#xa;event: thinking&#xa;event: planning&#xa;event: sql_ready&#xa;event: awaiting_approval&#xa;event: executing&#xa;event: result&#xa;event: reflecting&#xa;event: chart&#xa;event: conclusion&#xa;event: done" style="rounded=1;whiteSpace=wrap;fillColor=#FAFAFA;strokeColor=#999;fontSize=10;align=left;spacingLeft=8;fontFamily=monospace;" vertex="1" parent="1">
      <mxGeometry x="830" y="370" width="170" height="210" as="geometry"/>
    </mxCell>

    <!-- Checkpointer -->
    <mxCell id="checkpoint" value="MemorySaver Checkpointer&#xa;(状态持久化 + 恢复)" style="rounded=1;whiteSpace=wrap;fillColor=#F5F5F5;strokeColor=#666;fontSize=10;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="830" y="310" width="170" height="40" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>