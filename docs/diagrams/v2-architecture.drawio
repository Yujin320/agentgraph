<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Title -->
    <mxCell id="title" value="DataAgent v2 - 系统分层架构" style="text;fontSize=20;fontStyle=1;fontColor=#1a1a2e;align=center;" vertex="1" parent="1">
      <mxGeometry x="200" y="10" width="560" height="30" as="geometry"/>
    </mxCell>

    <!-- Layer 1: Presentation Layer -->
    <mxCell id="layer1_bg" value="" style="rounded=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;opacity=40;" vertex="1" parent="1">
      <mxGeometry x="40" y="50" width="880" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="layer1_label" value="展示层 Presentation" style="text;fontSize=14;fontStyle=1;fontColor=#E65100;align=left;" vertex="1" parent="1">
      <mxGeometry x="55" y="55" width="200" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="p1" value="实时推理流展示&#xa;(SSE Named Events)" style="rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="60" y="90" width="150" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="p2" value="归因路径&#xa;交互式 DAG" style="rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="230" y="90" width="130" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="p3" value="内联 SQL 编辑器&#xa;(Approve / Edit)" style="rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="380" y="90" width="140" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="p4" value="自动图表选择器&#xa;(ECharts)" style="rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="540" y="90" width="130" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="p5" value="策略选择器&#xa;+ 场景 KPI" style="rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="690" y="90" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- Arrow: Presentation -> Reasoning -->
    <mxCell id="arrow_pr" value="SSE + REST + interrupt()" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555;fontSize=10;fontColor=#555;" edge="1" parent="1" source="layer1_bg" target="layer2_bg">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Layer 2: Reasoning Engine Layer -->
    <mxCell id="layer2_bg" value="" style="rounded=1;fillColor=#E8EAF6;strokeColor=#283593;strokeWidth=2;opacity=40;" vertex="1" parent="1">
      <mxGeometry x="40" y="220" width="880" height="200" as="geometry"/>
    </mxCell>
    <mxCell id="layer2_label" value="推理引擎层 Reasoning Engine (LangGraph)" style="text;fontSize=14;fontStyle=1;fontColor=#283593;align=left;" vertex="1" parent="1">
      <mxGeometry x="55" y="225" width="400" height="25" as="geometry"/>
    </mxCell>

    <!-- Main Loop Nodes -->
    <mxCell id="n_intent" value="Intent&#xa;意图识别" style="rounded=1;whiteSpace=wrap;fillColor=#C5CAE9;strokeColor=#283593;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="265" width="90" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="n_plan" value="Plan&#xa;任务分解" style="rounded=1;whiteSpace=wrap;fillColor=#C5CAE9;strokeColor=#283593;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="175" y="265" width="90" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="n_sqlgen" value="SQL Gen&#xa;SQL 生成" style="rounded=1;whiteSpace=wrap;fillColor=#C5CAE9;strokeColor=#283593;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="290" y="265" width="90" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="n_exec" value="Execute&#xa;SQL 执行" style="rounded=1;whiteSpace=wrap;fillColor=#C5CAE9;strokeColor=#283593;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="405" y="265" width="90" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="n_reflect" value="Reflect&#xa;结果评估" style="rhombus;whiteSpace=wrap;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontStyle=1;" vertex="1" parent="1">
