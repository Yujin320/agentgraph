      <mxGeometry x="660" y="265" width="100" height="50" as="geometry"/>
    </mxCell>

    <!-- Main flow edges -->
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#283593;" edge="1" parent="1" source="n_intent" target="n_plan">
